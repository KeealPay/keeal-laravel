{
  "name": "keeal/laravel-checkout",
  "description": "Laravel integration for Keeal hosted checkout",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "keeal",
    "laravel",
    "checkout",
    "payments"
  ],
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/routing": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "keeal/keeal-php": "^0.2"
  },
  "require-dev": {
    "laravel/pint": "^1.18",
    "orchestra/testbench": "^9.0|^10.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/KeealPay/keeal-php"
    }
  ],
  "autoload": {
    "psr-4": {
      "Keeal\\LaravelCheckout\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Keeal\\LaravelCheckout\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Keeal\\LaravelCheckout\\KeealCheckoutServiceProvider"
      ],
      "aliases": {
        "Keeal": "Keeal\\LaravelCheckout\\Facades\\Keeal",
        "KeealPublic": "Keeal\\LaravelCheckout\\Facades\\KeealPublic"
      }
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "lint": "pint",
    "analyse": "phpstan analyse --memory-limit=512M"
  },
  "prefer-stable": true
}
